# Microsoft Entra (Azure AD) App Registration credentials
# Required Graph API permissions (Application):
#   User.Read.All
#   Directory.Read.All
#   AuditLog.Read.All
#   UserAuthenticationMethod.Read.All
#   Reports.Read.All

TENANT_ID=your-tenant-id-here
CLIENT_ID=your-app-client-id-here
CLIENT_SECRET=your-app-client-secret-here

# Optional: days of inactivity before account is flagged as stale
STALE_DAYS=90
